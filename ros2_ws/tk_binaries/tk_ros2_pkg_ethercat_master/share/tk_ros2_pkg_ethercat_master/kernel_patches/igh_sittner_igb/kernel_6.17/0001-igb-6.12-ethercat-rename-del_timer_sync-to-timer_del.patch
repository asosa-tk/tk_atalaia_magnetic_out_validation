From 1bbfeb2e17d1d6307bdb26e74622aa0d3d8b72e8 Mon Sep 17 00:00:00 2001
From: EtherCAT Kernel Port <ecat-port@local>
Date: Mon, 18 May 2026 17:14:46 +0200
Subject: [PATCH 1/4] igb 6.12-ethercat: rename del_timer_sync to
 timer_delete_sync (kernel 6.17)
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Kernel 6.17 renamed del_timer_sync() to timer_delete_sync() as part of the
ongoing timer API consolidation (Thomas Gleixner, Linus tree). Without this
the IgH-patched igb driver fails to link against kernel 6.17 headers with
'implicit declaration of function del_timer_sync'.

Affects two call sites in igb_close() and igb_remove():
  del_timer_sync(&adapter->watchdog_timer);
  del_timer_sync(&adapter->phy_info_timer);

The new symbol is a 1:1 rename — semantics, signature, and behavior are
identical. Backport-safe to 6.12 because timer_delete_sync was added as
an alias well before the rename.
---
 devices/igb/igb_main-6.12-ethercat.c | 8 ++++----
 1 file changed, 4 insertions(+), 4 deletions(-)

diff --git a/devices/igb/igb_main-6.12-ethercat.c b/devices/igb/igb_main-6.12-ethercat.c
index 75d1dcd..d087574 100644
--- a/devices/igb/igb_main-6.12-ethercat.c
+++ b/devices/igb/igb_main-6.12-ethercat.c
@@ -2201,8 +2201,8 @@ void igb_down(struct igb_adapter *adapter)
 		}
 	}
 
-	del_timer_sync(&adapter->watchdog_timer);
-	del_timer_sync(&adapter->phy_info_timer);
+	timer_delete_sync(&adapter->watchdog_timer);
+	timer_delete_sync(&adapter->phy_info_timer);
 
 	/* record the stats before reset*/
 	spin_lock(&adapter->stats64_lock);
@@ -3955,8 +3955,8 @@ static void igb_remove(struct pci_dev *pdev)
 	 * disable watchdog from being rescheduled.
 	 */
 	set_bit(__IGB_DOWN, &adapter->state);
-	del_timer_sync(&adapter->watchdog_timer);
-	del_timer_sync(&adapter->phy_info_timer);
+	timer_delete_sync(&adapter->watchdog_timer);
+	timer_delete_sync(&adapter->phy_info_timer);
 
 	cancel_work_sync(&adapter->reset_task);
 	cancel_work_sync(&adapter->watchdog_task);
